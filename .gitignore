.DS_Store
.mplconfig/
__pycache__/
*.pyc

# Raw XTraffic data and generated caches are too large for GitHub.
archive/
*.npy
*.h5
*.npz

# Model checkpoints and rendered figures are regenerated locally.
*.pt
*.png

# Local papers/reference PDFs stay local unless explicitly added later.
论文/
*.pdf

# IGSTGNN: vendored source only (src/, README, LICENSE, requirements).
# Skip their converted data + trained checkpoints.
baselines/IGSTGNN/data/
baselines/IGSTGNN/experiments/
baselines/IGSTGNN/img/

# Outputs ignored by default; markdown / CSV summaries force-added explicitly.
outputs/**
!outputs/setting_a_artifacts/
!outputs/setting_a_artifacts/**
!outputs/paper_artifacts/
!outputs/paper_artifacts/*.md
!outputs/paper_artifacts/tables/
!outputs/paper_artifacts/tables/**
!outputs/fourier_dual_net/paper_artifacts/
!outputs/fourier_dual_net/paper_artifacts/**
!outputs/igstgnn_ours_pipeline_fixed/setting_a_breakdown.json

# Allow PNG figures only inside committed artifact dirs.
!outputs/setting_a_artifacts/*.png
!outputs/paper_artifacts/figures/
!outputs/paper_artifacts/figures/**
